# Server
PORT={{PORT_BACKEND}}
NODE_ENV=development

# MongoDB (Atlas — replicant init --atlas lo configura automáticamente)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/{{DB_NAME}}?retryWrites=true&w=majority
# Para desarrollo local sin Atlas, usar:
# MONGODB_URI=mongodb://localhost:27017/{{DB_NAME}}

# Auth0 (replicant init --auth0 lo configura automáticamente)
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_AUDIENCE=https://api.{{PROYECTO_LOWER}}.norpan.com
SKIP_AUTH=true

# Auth0 Management API (M2M) — para crear/gestionar usuarios desde el backend
# Configurar en: Auth0 Dashboard → Applications → APIs → Auth0 Management API
AUTH0_MANAGEMENT_CLIENT_ID=
AUTH0_MANAGEMENT_CLIENT_SECRET=

# CORS
CORS_ORIGIN=http://localhost:{{PORT_FRONTEND}}
